{
    "name": "bughq/bughq",
    "description": "bughq error tracking - PHP SDK",
    "type": "library",
    "license": "MIT",
    "homepage": "https://bughq.org",
    "keywords": ["bughq", "error-tracking", "error-monitoring", "crash-reporting", "php"],
    "support": {
        "issues": "https://github.com/bughq/bughq-php/issues",
        "source": "https://github.com/bughq/bughq-php"
    },
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "BugHQ\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BugHQ\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
